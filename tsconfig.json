{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "@pages": ["pages/index"],
      "@pages/*": ["pages/*"],
      "@locators": ["locators/index"],
      "@locators/*": ["locators/*"],
      "@components": ["components/index"],
      "@components/*": ["components/*"],
      "@fixtures": ["fixtures/index"],
      "@fixtures/*": ["fixtures/*"],
      "@utils": ["utils/index"],
      "@utils/*": ["utils/*"],
      "@test-data": ["test-data/index"],
      "@test-data/*": ["test-data/*"],
      "@api-services": ["api-services/index"],
      "@api-services/*": ["api-services/*"],
      "@constants": ["constants/index"],
      "@constants/*": ["constants/*"],
      "@config": ["config/index"],
      "@config/*": ["config/*"],
      "@environments": ["environments/index"],
      "@environments/*": ["environments/*"],
      "@hooks": ["hooks/index"],
      "@hooks/*": ["hooks/*"],
      "@types-custom": ["types/index"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test-results",
    "reports"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
